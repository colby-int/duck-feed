# Copy this file to .env before starting the stack.
# Generate SESSION_SECRET with: openssl rand -hex 32
#
# PostgreSQL
POSTGRES_USER=duckfeed
POSTGRES_PASSWORD=changeme
POSTGRES_DB=duckfeed

# API Server
DATABASE_URL=postgresql://duckfeed:changeme@postgres:5432/duckfeed
SESSION_SECRET=generate-a-64-char-random-string-here
LOG_LEVEL=info
PORT=3000
# Optional: cap concurrent worker ingests to protect small hosts during bulk uploads.
INGEST_MAX_CONCURRENCY=1

# Icecast
ICECAST_SOURCE_PASSWORD=changeme-source
ICECAST_ADMIN_PASSWORD=changeme-admin
# Set this to the public stream host. In split-origin production deployments,
# use the stream host (for example `stream.radio.example.com`) rather than the
# app host so Icecast metadata advertises a valid TLS URL.
ICECAST_HOSTNAME=localhost

# AcoustID (optional — fingerprinting disabled without this)
# ACOUSTID_API_KEY=
MUSICBRAINZ_CONTACT_URL=https://github.com/your-username/duck-feed

# Stream
LIQUIDSOAP_TELNET_HOST=liquidsoap
LIQUIDSOAP_TELNET_PORT=1234

# Branding uploads (optional)
BRANDING_DIR=/var/lib/duckfeed/branding
